{
  "$schema": "node_modules/@ztools-center/ztools-api-types/resource/ztools.schema.json",
  "name": "tinypng",
  "title": "TinyPNG 压缩图片",
  "description": "使用 TinyPNG 压缩图片",
  "author": "Zing",
  "version": "1.0.0",
  "main": "index.html",
  "preload": "preload/services.js",
  "logo": "logo.png",
  "development": {
    "main": "http://localhost:5173"
  },
  "pluginSetting": {
    "single": true,
    "height": 600
  },
  "features": [
    {
      "code": "tinypng",
      "explain": "压缩图片",
      "icon": "logo.png",
      "cmds": [
        "tinypng",
        "压缩图片",
        {
          "type": "files",
          "fileType": "file",
          "label": "压缩图片",
          "extensions": ["png", "jpg", "jpeg", "webp"]
        },
        {
          "type": "files",
          "fileType": "directory",
          "label": "压缩此文件夹下所有图片"
        }
      ]
    }
  ]
}
